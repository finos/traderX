+    } catch (Exception x) {
+      throw new PubSubException("Cannot connect to NATS at " + serverAddress, x);
+    }
+  }
+
+  @Override
+  public void afterPropertiesSet() throws Exception {
+    connect();
+    subscribe(defaultTopic);
+  }
+}
