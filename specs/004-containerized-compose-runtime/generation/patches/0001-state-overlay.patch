+    return ResponseEntity.ok(true);
+  }
+
+  @ExceptionHandler(Exception.class)
+  public ResponseEntity<String> generalError(Exception e) {
+    return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(e.getMessage());
+  }
+}
