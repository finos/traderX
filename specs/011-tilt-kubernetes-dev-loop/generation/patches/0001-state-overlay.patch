+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: observability-grafana-datasources
+  namespace: traderx
+data:
+  datasources.yaml: |
+    apiVersion: 1
+    
+    datasources:
+      - name: Prometheus
+        uid: prometheus
+        type: prometheus
+        access: proxy
+        url: http://prometheus:9090/prometheus
+        isDefault: true
+    
+      - name: Loki
+        uid: loki
+        type: loki
+        access: proxy
+        url: http://loki:3100
+    
+      - name: Tempo
+        uid: tempo
+        type: tempo
+        access: proxy
+        url: http://tempo:3200
+        jsonData:
+          httpMethod: GET
+          tracesToLogs:
+            datasourceUid: loki
+          serviceMap:
+            datasourceUid: prometheus
diff --git a/tilt-kubernetes-dev-loop/manifests/base/observability-loki-configmap.yaml b/tilt-kubernetes-dev-loop/manifests/base/observability-loki-configmap.yaml
new file mode 100644
index 0000000..856496a
--- /dev/null
+++ b/tilt-kubernetes-dev-loop/manifests/base/observability-loki-configmap.yaml
@@ -0,0 +1,38 @@
+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: observability-loki-config
+  namespace: traderx
+data:
+  config.yaml: |
+    auth_enabled: false
+    
+    server:
+      http_listen_port: 3100
+      grpc_listen_port: 9096
+    
+    common:
+      path_prefix: /tmp/loki
+      storage:
+        filesystem:
+          chunks_directory: /tmp/loki/chunks
+          rules_directory: /tmp/loki/rules
+      replication_factor: 1
+      ring:
+        kvstore:
+          store: inmemory
+    
+    schema_config:
+      configs:
+        - from: "2024-01-01"
+          store: tsdb
+          object_store: filesystem
+          schema: v13
+          index:
+            prefix: index_
+            period: 24h
+    
+    limits_config:
+      allow_structured_metadata: false
