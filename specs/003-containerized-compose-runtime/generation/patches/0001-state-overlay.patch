diff --git a/account-service/Dockerfile.compose b/account-service/Dockerfile.compose
new file mode 100644
index 0000000..6237054
--- /dev/null
+++ b/account-service/Dockerfile.compose
@@ -0,0 +1,14 @@
+# syntax=docker/dockerfile:1.7
+FROM eclipse-temurin:21-jdk AS build
+WORKDIR /app
+COPY . .
+RUN --mount=type=cache,target=/root/.gradle,sharing=locked \
+    chmod +x gradlew && ./gradlew --no-daemon clean bootJar \
+ && jar_path="$(ls -1 build/libs/*.jar | grep -v -- '-plain\.jar$' | head -n 1)" \
+ && cp "${jar_path}" build/libs/app.jar
+
+FROM eclipse-temurin:21-jre
+WORKDIR /opt/app
+COPY --from=build /app/build/libs/app.jar app.jar
+EXPOSE 18088
+ENTRYPOINT ["java", "-jar", "/opt/app/app.jar"]
