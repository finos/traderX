{
  "stateId": "003-containerized-compose-runtime",
  "title": "Architecture (State 003 Containerized Compose Runtime)",
  "description": "State 003 preserves state 002 routing semantics while moving runtime to Docker Compose and NGINX ingress.",
  "inheritsFrom": "002-edge-proxy-uncontainerized",
  "flowDoc": "../001-baseline-uncontainerized-parity/system/end-to-end-flows.md",
  "entrypoints": [
    {
      "name": "ingress",
      "url": "http://localhost:8080"
    },
    {
      "name": "angular-debug",
      "url": "http://localhost:18093"
    }
  ],
  "nodes": [
    {
      "id": "trader",
      "label": "Trader Browser",
      "kind": "actor",
      "description": "User traffic enters through ingress."
    },
    {
      "id": "ingress",
      "label": "NGINX Ingress",
      "kind": "gateway",
      "description": "Compose ingress for UI/API/WebSocket routes."
    },
    {
      "id": "web",
      "label": "Web Front End Angular",
      "kind": "frontend",
      "description": "Containerized Angular service."
    },
    {
      "id": "account",
      "label": "Account Service",
      "kind": "service",
      "description": "Containerized Spring service."
    },
    {
      "id": "position",
      "label": "Position Service",
      "kind": "service",
      "description": "Containerized Spring service."
    },
    {
      "id": "tradeService",
      "label": "Trade Service",
      "kind": "service",
      "description": "Containerized Spring service."
    },
    {
      "id": "referenceData",
      "label": "Reference Data",
      "kind": "service",
      "description": "Containerized Node service."
    },
    {
      "id": "people",
      "label": "People Service",
      "kind": "service",
      "description": "Containerized .NET service."
    },
    {
      "id": "tradeFeed",
      "label": "Trade Feed",
      "kind": "messaging",
      "description": "Containerized Socket.IO bus."
    },
    {
      "id": "tradeProcessor",
      "label": "Trade Processor",
      "kind": "service",
      "description": "Containerized Spring service."
    },
    {
      "id": "database",
      "label": "Database",
      "kind": "database",
      "description": "Containerized H2 persistence service."
    }
  ],
  "edges": [
    {
      "from": "trader",
      "to": "ingress",
      "label": "Single browser entrypoint"
    },
    {
      "from": "ingress",
      "to": "web",
      "label": "/"
    },
    {
      "from": "ingress",
      "to": "account",
      "label": "/account-service"
    },
    {
      "from": "ingress",
      "to": "position",
      "label": "/position-service"
    },
    {
      "from": "ingress",
      "to": "tradeService",
      "label": "/trade-service"
    },
    {
      "from": "ingress",
      "to": "referenceData",
      "label": "/reference-data"
    },
    {
      "from": "ingress",
      "to": "people",
      "label": "/people-service"
    },
    {
      "from": "ingress",
      "to": "tradeFeed",
      "label": "/trade-feed and /socket.io"
    },
    {
      "from": "tradeService",
      "to": "account",
      "label": "Validate account"
    },
    {
      "from": "tradeService",
      "to": "referenceData",
      "label": "Validate ticker"
    },
    {
      "from": "tradeService",
      "to": "tradeFeed",
      "label": "Publish trades/new"
    },
    {
      "from": "tradeProcessor",
      "to": "tradeFeed",
      "label": "Consume and publish updates"
    },
    {
      "from": "tradeProcessor",
      "to": "database",
      "label": "Persist trade/position state"
    },
    {
      "from": "account",
      "to": "database",
      "label": "Account persistence"
    },
    {
      "from": "position",
      "to": "database",
      "label": "Query trades/positions"
    },
    {
      "from": "account",
      "to": "people",
      "label": "Validate person for account-user mapping"
    }
  ],
  "notes": [
    "State 003 preserves approved baseline functional behavior while changing runtime/ops model.",
    "Inter-service network resolution uses Docker Compose service DNS names."
  ]
}
