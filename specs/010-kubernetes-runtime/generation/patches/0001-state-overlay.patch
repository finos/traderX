+apiVersion: v1
+kind: ConfigMap
+metadata:
+  name: observability-otel-collector-config
+  namespace: traderx
+data:
+  config.yaml: |
+    extensions:
+      health_check:
+        endpoint: 0.0.0.0:13133
+    
+    receivers:
+      otlp:
+        protocols:
+          grpc:
+            endpoint: 0.0.0.0:4317
+          http:
+            endpoint: 0.0.0.0:4318
+    
+    processors:
+      batch:
+        timeout: 1s
+    
+    exporters:
+      logging:
+        verbosity: normal
