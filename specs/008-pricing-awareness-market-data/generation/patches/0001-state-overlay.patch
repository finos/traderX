+            return '-';
+        }
+        return new Intl.NumberFormat('en-US', {
+            style: 'currency',
+            currency: 'USD',
+            minimumFractionDigits: 3,
+            maximumFractionDigits: 3
+        }).format(numeric);
+    }
+
