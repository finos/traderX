+<div class="order-admin-container p-4">
+  <h4 class="mb-2">Order Matcher Admin</h4>
+  <div class="text-muted mb-3">
+    Open orders with live market price stream (<code>pricing.&lt;TICKER&gt;</code>) shown next to strike.
+  </div>
+
+  <div
+    *ngIf="actionMessage"
+    class="alert py-2 px-3"
+    [ngClass]="actionMessage.type === 'success' ? 'alert-success' : 'alert-danger'">
+    {{ actionMessage.text }}
+  </div>
+
+  <div class="row mb-3">
+    <div class="col-sm-4">
+      <div class="alert alert-secondary py-2 px-3 mb-0">
+        Open Orders: <strong>{{ openOrderCount }}</strong>
+      </div>
+    </div>
+    <div class="col-sm-4">
+      <div class="alert alert-secondary py-2 px-3 mb-0">
+        Unfilled Orders: <strong>{{ unfilledOrderCount }}</strong>
+      </div>
+    </div>
+    <div class="col-sm-4">
+      <div class="alert alert-secondary py-2 px-3 mb-0">
+        Remaining Quantity: <strong>{{ totalRemainingQuantity | number:'1.0-0' }}</strong>
+      </div>
+    </div>
+  </div>
+
+  <ag-grid-angular
+    style="width: 100%; height: 520px;"
+    class="ag-theme-alpine"
+    [columnDefs]="columnDefs"
+    [rowData]="rows"
+    [getRowId]="getRowId"
+    (cellClicked)="onCellClicked($event)"
+    (gridReady)="onGridReady($event)">
+  </ag-grid-angular>
+</div>
