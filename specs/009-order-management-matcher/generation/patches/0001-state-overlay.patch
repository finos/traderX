+  }
+  implementation 'ch.qos.logback:logback-classic:1.5.32'
+
+  testImplementation 'org.springframework.boot:spring-boot-starter-test'
+}
+
+tasks.withType(Test).configureEach {
+  useJUnitPlatform()
+}
