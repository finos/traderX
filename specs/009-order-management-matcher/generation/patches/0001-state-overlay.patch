+import { TradeFeedService } from 'main/app/service/trade-feed.service';
+
+type OrderRow = OrderRecord & {
+  marketPrice?: number;
+  spreadToStrike?: number;
+  accountDisplayName?: string;
+};
+
+@Component({
+  standalone: false,
