+    <div class="col-sm-4">
+      <div class="alert alert-secondary py-2 px-3 mb-0">
+        Remaining Quantity: <strong>{{ totalRemainingQuantity | number:'1.0-0' }}</strong>
+      </div>
+    </div>
+  </div>
+
