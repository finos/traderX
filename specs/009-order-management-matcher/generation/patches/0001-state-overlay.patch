+name: traderx-state-013
+
+services:
+  database:
+    image: postgres:16-alpine
+    environment:
+      POSTGRES_DB: "traderx"
+      POSTGRES_USER: "traderx"
+      POSTGRES_PASSWORD: "traderx"
+    ports:
+      - "18083:5432"
+    healthcheck:
+      test: [ "CMD-SHELL", "pg_isready -U traderx -d traderx" ]
+      interval: 5s
+      timeout: 5s
+      retries: 20
+    volumes:
+      - postgres_state_009_data:/var/lib/postgresql/data
+      - ../postgres-database-replacement/postgres-init/initialSchema.sql:/docker-entrypoint-initdb.d/001-initialSchema.sql:ro
+
+  reference-data:
+    build:
+      context: ../reference-data
+      dockerfile: Dockerfile.compose
+    environment:
+      REFERENCE_DATA_SERVICE_PORT: "18085"
+      CORS_ALLOWED_ORIGINS: "http://localhost:8080"
+      REFERENCE_DATA_SUPPORTED_TICKERS: "${SUPPORTED_TICKERS:-AAPL,MSFT,AMZN,GOOGL,META,NVDA,TSLA,IBM,BAC,C,JPM,GS,MS,UBS,DB,COF,DFS,FNMA,FIS,FNF}"
+    ports:
+      - "18085:18085"
+    depends_on:
+      - database
+
+  nats-broker:
+    image: nats:2.10-alpine
+    command: ["-c", "/etc/nats/nats.conf"]
+    volumes:
+      - ./nats/nats.conf:/etc/nats/nats.conf:ro
+    ports:
+      - "4222:4222"
+      - "8222:8222"
+      - "8081:8081"
+
+  price-publisher:
+    build:
+      context: ../price-publisher
+      dockerfile: Dockerfile.compose
+    environment:
+      PRICE_PUBLISHER_PORT: "18100"
+      NATS_BROKER_HOST: "nats-broker"
+      PRICE_BOOTSTRAP_MODE: "${PRICE_BOOTSTRAP_MODE:-snapshot}"
+      PRICE_TICKERS: "${SUPPORTED_TICKERS:-AAPL,MSFT,AMZN,GOOGL,META,NVDA,TSLA,IBM,BAC,C,JPM,GS,MS,UBS,DB,COF,DFS,FNMA,FIS,FNF}"
+    ports:
+      - "18100:18100"
+    depends_on:
+      - nats-broker
+
+  people-service:
+    build:
+      context: ../people-service
+      dockerfile: Dockerfile.compose
+    environment:
+      PEOPLE_SERVICE_PORT: "18089"
+      CORS_ALLOWED_ORIGINS: "http://localhost:8080"
+    ports:
+      - "18089:18089"
+
+  account-service:
+    build:
+      context: ../account-service
+      dockerfile: Dockerfile.compose
+    environment:
+      ACCOUNT_SERVICE_PORT: "18088"
+      DATABASE_PG_HOST: "database"
+      DATABASE_PG_PORT: "5432"
+      DATABASE_NAME: "traderx"
+      DATABASE_DBUSER: "traderx"
+      DATABASE_DBPASS: "traderx"
+      PEOPLE_SERVICE_HOST: "people-service"
+      CORS_ALLOWED_ORIGINS: "http://localhost:8080"
+    ports:
+      - "18088:18088"
+    depends_on:
+      database:
+        condition: service_healthy
+      people-service:
+        condition: service_started
+
+  position-service:
+    build:
+      context: ../position-service
+      dockerfile: Dockerfile.compose
+    environment:
+      POSITION_SERVICE_PORT: "18090"
+      DATABASE_PG_HOST: "database"
+      DATABASE_PG_PORT: "5432"
+      DATABASE_NAME: "traderx"
+      DATABASE_DBUSER: "traderx"
+      DATABASE_DBPASS: "traderx"
+      CORS_ALLOWED_ORIGINS: "http://localhost:8080"
+    ports:
+      - "18090:18090"
+    depends_on:
+      database:
+        condition: service_healthy
+
+  trade-processor:
+    build:
+      context: ../trade-processor
+      dockerfile: Dockerfile.compose
+    environment:
+      TRADE_PROCESSOR_SERVICE_PORT: "18091"
+      DATABASE_PG_HOST: "database"
+      DATABASE_PG_PORT: "5432"
+      DATABASE_NAME: "traderx"
+      DATABASE_DBUSER: "traderx"
+      DATABASE_DBPASS: "traderx"
+      NATS_BROKER_HOST: "nats-broker"
+      CORS_ALLOWED_ORIGINS: "http://localhost:8080"
+    ports:
+      - "18091:18091"
+    depends_on:
+      database:
+        condition: service_healthy
+      nats-broker:
+        condition: service_started
+
+  trade-service:
+    build:
+      context: ../trade-service
+      dockerfile: Dockerfile.compose
+    environment:
+      TRADING_SERVICE_PORT: "18092"
+      ACCOUNT_SERVICE_HOST: "account-service"
+      REFERENCE_DATA_HOST: "reference-data"
+      PEOPLE_SERVICE_HOST: "people-service"
+      NATS_BROKER_HOST: "nats-broker"
+      PRICE_SERVICE_HOST: "price-publisher"
+      CORS_ALLOWED_ORIGINS: "http://localhost:8080"
+    ports:
+      - "18092:18092"
+    depends_on:
+      - account-service
+      - reference-data
+      - people-service
+      - nats-broker
+      - price-publisher
+      - trade-processor
+
+  web-front-end-angular:
+    build:
+      context: ../web-front-end/angular
+      dockerfile: Dockerfile.compose
+    environment:
+      WEB_SERVICE_PORT: "18093"
+    ports:
+      - "18093:18093"
+    depends_on:
+      - account-service
+      - reference-data
+      - trade-service
+      - position-service
+      - people-service
+      - nats-broker
+
+  order-matcher:
+    build:
+      context: ../order-matcher
+      dockerfile: Dockerfile.compose
+    environment:
+      ORDER_MATCHER_PORT: "18110"
+      DATABASE_PG_HOST: "database"
+      DATABASE_PG_PORT: "5432"
+      DATABASE_NAME: "traderx"
+      DATABASE_DBUSER: "traderx"
+      DATABASE_DBPASS: "traderx"
+      CORS_ALLOWED_ORIGINS: "http://localhost:8080"
+      PRICE_SERVICE_URL: "http://price-publisher:18100"
+      TRADE_SERVICE_URL: "http://trade-service:18092/trade/"
+      ORDER_MATCHER_TICK_MS: "${ORDER_MATCHER_TICK_MS:-1000}"
+      ORDER_FILL_FULL_THRESHOLD: "${ORDER_FILL_FULL_THRESHOLD:-1000}"
+    ports:
+      - "18110:18110"
+    depends_on:
+      database:
+        condition: service_healthy
+      price-publisher:
+        condition: service_started
+      trade-service:
+        condition: service_started
+
+  ingress:
+    build:
+      context: ../ingress
+      dockerfile: Dockerfile.compose
+    environment:
+      NGINX_HOST: "localhost"
+      DATABASE_URL: "http://database:5432/"
+      REFERENCE_DATA_URL: "http://reference-data:18085/"
+      PEOPLE_SERVICE_URL: "http://people-service:18089/"
+      ACCOUNT_SERVICE_URL: "http://account-service:18088/"
+      POSITION_SERVICE_URL: "http://position-service:18090/"
+      TRADE_PROCESSOR_URL: "http://trade-processor:18091/"
+      TRADE_SERVICE_URL: "http://trade-service:18092/"
+      PRICE_PUBLISHER_URL: "http://price-publisher:18100/"
+      ORDER_MATCHER_URL: "http://order-matcher:18110/"
+      WEB_FRONTEND_URL: "http://web-front-end-angular:18093/"
+    ports:
+      - "8080:8080"
+    depends_on:
+      - web-front-end-angular
+      - account-service
+      - reference-data
+      - trade-service
+      - position-service
+      - people-service
+      - nats-broker
+      - price-publisher
+      - order-matcher
+
+  otel-collector:
+    image: otel/opentelemetry-collector-contrib:0.103.1
+    command: ["--config=/etc/otelcol-contrib/config.yaml"]
+    volumes:
+      - ./observability/otel-collector/config.yaml:/etc/otelcol-contrib/config.yaml:ro
+    ports:
+      - "4317:4317"
+      - "4318:4318"
+      - "8888:8888"
+      - "8889:8889"
+      - "13133:13133"
+    depends_on:
+      - tempo
+
+  blackbox-exporter:
+    image: prom/blackbox-exporter:v0.25.0
+    command: ["--config.file=/etc/blackbox_exporter/config.yml"]
+    volumes:
+      - ./observability/blackbox/blackbox.yml:/etc/blackbox_exporter/config.yml:ro
+    ports:
+      - "9115:9115"
+
+  prometheus:
+    image: prom/prometheus:v2.53.2
+    command: ["--config.file=/etc/prometheus/prometheus.yml", "--web.enable-lifecycle"]
+    volumes:
+      - ./observability/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
+    ports:
+      - "9090:9090"
+    depends_on:
+      - blackbox-exporter
+      - otel-collector
+
+  loki:
+    image: grafana/loki:2.9.8
+    command: ["-config.file=/etc/loki/config.yaml"]
+    volumes:
+      - ./observability/loki/config.yaml:/etc/loki/config.yaml:ro
+    ports:
+      - "3100:3100"
+
+  promtail:
+    image: grafana/promtail:2.9.8
+    command: ["-config.file=/etc/promtail/config.yaml"]
+    volumes:
