+<div class="order-admin-container p-4">
+  <h4 class="mb-2">Order Matcher Admin</h4>
+  <div class="text-muted mb-3">
+    Open orders with live market price stream (<code>pricing.&lt;TICKER&gt;</code>) shown next to strike.
+  </div>
+
+  <div
+    *ngIf="actionMessage"
+    class="alert py-2 px-3"
+    [ngClass]="actionMessage.type === 'success' ? 'alert-success' : 'alert-danger'">
