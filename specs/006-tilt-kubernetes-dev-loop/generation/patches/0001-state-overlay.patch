+)
+k8s_resource('position-service')
+
+docker_build(
+    'traderx/trade-processor:state004',
+    '../trade-processor',
+    dockerfile='../trade-processor/Dockerfile.compose',
+)
+k8s_resource('trade-processor')
+
+docker_build(
