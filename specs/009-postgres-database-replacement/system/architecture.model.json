      "description": "Socket.IO pub/sub layer (unchanged from state 003)."
    },
    {
      "id": "people",
      "label": "People Service",
      "kind": "service",
      "description": "Identity lookup and validation."
    },
    {
      "id": "account",
      "label": "Account Service",
      "kind": "service",
      "description": "Account and account-user operations using PostgreSQL."
    },
    {
      "id": "position",
      "label": "Position Service",
      "kind": "service",
      "description": "Trades/positions query operations using PostgreSQL."
    },
    {
      "id": "tradeProcessor",
      "label": "Trade Processor",
      "kind": "service",
      "description": "Trade processing and persistence using PostgreSQL."
    },
    {
      "id": "tradeService",
      "label": "Trade Service",
      "kind": "service",
      "description": "Trade submission and validation."
    },
    {
      "id": "database",
      "label": "PostgreSQL Database",
      "kind": "database",
      "description": "Persistent account/trade/position state."
    }
