    {
      "from": "ingress",
      "to": "account",
      "label": "/account-service"
    },
    {
      "from": "ingress",
      "to": "position",
      "label": "/position-service"
    },
    {
      "from": "ingress",
      "to": "tradeService",
      "label": "/trade-service"
    },
    {
      "from": "ingress",
      "to": "referenceData",
      "label": "/reference-data"
    },
    {
      "from": "ingress",
      "to": "people",
      "label": "/people-service"
    },
    {
      "from": "ingress",
      "to": "tradeFeed",
      "label": "/trade-feed (WS)"
    },
    {
      "from": "tradeService",
      "to": "account",
      "label": "Validate account"
    },
    {
      "from": "tradeService",
      "to": "referenceData",
      "label": "Validate ticker"
