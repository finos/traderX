      "description": "Uses Angular UI via ingress."
    },
    {
      "id": "ingress",
      "label": "NGINX Ingress",
      "kind": "gateway",
      "description": "Single browser entrypoint for UI + API + websocket."
    },
    {
      "id": "web",
      "label": "Web Front End Angular",
      "kind": "frontend",
      "description": "TraderX UI."
    },
    {
      "id": "referenceData",
      "label": "Reference Data",
      "kind": "service",
      "description": "Ticker lookup/list."
    },
    {
      "id": "tradeFeed",
      "label": "Trade Feed",
