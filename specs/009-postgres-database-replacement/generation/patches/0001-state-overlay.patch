+  side VARCHAR(10) CHECK (side in ('Buy', 'Sell')),
+  quantity INTEGER CHECK (quantity > 0),
+  state VARCHAR(20) CHECK (state in ('New', 'Processing', 'Settled', 'Cancelled'))
+);
