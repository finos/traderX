{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TraderX Guide Frontmatter",
  "type": "object",
  "required": [
    "id",
    "title",
    "level",
    "prereqs",
    "outcomes",
    "state",
    "tags",
    "estimatedTimeMins",
    "owner"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^learn-[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "prereqs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "state": {
      "type": "object",
      "required": [
        "id",
        "diffFromPrev"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "00-monolith",
            "01-basic-microservices",
            "02-containerized",
            "03-service-mesh",
            "04-contract-driven",
            "05-ai-first"
          ]
        },
        "diffFromPrev": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "estimatedTimeMins": {
      "type": "integer",
      "minimum": 1
    },
    "owner": {
      "type": "string",
      "minLength": 2
    }
  },
  "additionalProperties": true
}
